# ──────────────────────────────────────────────
# BloodLink — Centre Web (.env.local)
# Copier ce fichier en .env.local et remplir les valeurs
# ──────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# IA Chat — SangBot
# Provider prioritaire (gratuit, 14400 req/jour)
# Obtenu sur https://console.groq.com → Keys
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_KEY

# Provider fallback #1 (gratuit, 1500 req/jour)
# Obtenu sur https://aistudio.google.com → API Key
GOOGLE_GENERATIVE_AI_API_KEY=AIza_REPLACE_WITH_YOUR_KEY

# Provider fallback #2 (gratuit, limité)
# Obtenu sur https://openrouter.ai → Keys
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_KEY

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
