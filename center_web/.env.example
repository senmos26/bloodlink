# Frontend / Next.js example environment file (no secrets)
# Copy to .env.local and fill values.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_PUBLIC_ANON_KEY
# Never put the service role key here.

# ---- AI Assistant (OpenRouter) ----
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_YOUR_KEY
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mobile app URL for CORS
NEXT_PUBLIC_MOBILE_APP_URL=http://localhost:8081
NEXT_PUBLIC_DONOR_WEB_URL=http://localhost:3001
