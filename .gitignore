# --- Monorepo BloodLink Master Gitignore ---

# 1. Dependencies (All levels)
node_modules/
**/node_modules/
.pnp
.pnp.*

# 2. Environment Variables & Secrets (CRITICAL)
# This covers all subdirectories: admin_web, center_web, mobile_app, air_service, etc.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env*.local

# 3. Next.js (Admin & Center)
**/.next/
**/out/
**/build/

# 4. Mobile App (Expo / React Native)
.expo/
.expo-shared/
web-build/
**/ios/build/
**/android/build/
**/android/app/build/
**/android/.gradle/
*.apk
*.ipa
*.app
*.exe

# 5. Python / AI Service (FastAPI)
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd
**/.venv
**/venv
**/env
**/.pytest_cache
**/.ruff_cache
**/.mypy_cache
.python-version

# 6. IDE & OS
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# 7. Logs & Temporary
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
**/test-results/
**/dist/

# 8. Database & Supabase
.supabase/
**/supabase/.temp/

# 9. Files to KEEP (Negations)
!README.md
!**/README.md
!**/package.json
!**/tsconfig.json
!.gitignore
!**/SPEC_*.md
